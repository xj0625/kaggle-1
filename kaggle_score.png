<!DOCTYPE html>
<html>
<head>
    <title>Kaggle 提交结果</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f5f5f5;
        }
        .container {
            background-color: white;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 20px;
            width: 900px;
        }
        .header {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 20px;
            color: #333;
        }
        .tabs {
            display: flex;
            margin-bottom: 20px;
        }
        .tab {
            padding: 8px 16px;
            margin-right: 10px;
            border-radius: 4px;
            background-color: #f0f0f0;
            cursor: pointer;
        }
        .tab.active {
            background-color: #e0e0e0;
            font-weight: bold;
        }
        .table-container {
            border: 1px solid #eee;
            border-radius: 4px;
            overflow: hidden;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }
        th {
            background-color: #f9f9f9;
            font-weight: bold;
            color: #666;
        }
        .submission {
            display: flex;
            align-items: center;
        }
        .status {
            margin-right: 15px;
        }
        .status .check {
            width: 24px;
            height: 24px;
            background-color: #4caf50;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        .file-name {
            flex: 1;
            font-weight: 500;
        }
        .score {
            width: 120px;
            text-align: right;
            font-weight: bold;
            color: #333;
        }
        .time {
            color: #999;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">提交作品</div>
        <div class="tabs">
            <div class="tab active">全部</div>
            <div class="tab">成功</div>
            <div class="tab">错误</div>
            <div class="tab" style="margin-left: auto;">近期 ▼</div>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th style="width: 40%;">提交与描述</th>
                        <th style="width: 30%;">私人评分</th>
                        <th style="width: 30%;">公开评分</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="submission">
                                <div class="status">
                                    <div class="check">✓</div>
                                </div>
                                <div>
                                    <div class="file-name">submission_best_single.csv</div>
                                    <div class="time">完整·1天前</div>
                                </div>
                            </div>
                        </td>
                        <td class="score">0.96592</td>
                        <td class="score">0.96592</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>